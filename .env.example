NODE_ENV=development
PORT=3000

# Usa al menos 32 bytes aleatorios en producción.
JWT_SECRET=reemplaza-esto-por-un-secreto-largo-y-aleatorio

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=firmas_digitales_v2

MAX_UPLOAD_SIZE_MB=25

# Orígenes separados por coma. En desarrollo se permiten los localhost habituales.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Opcionales para el primer inicio tras importar firmas_digitales_v2.sql.
# Si se omiten, la aplicación genera contraseñas aleatorias y las muestra una sola vez.
INITIAL_ADMIN_PASSWORD=
INITIAL_OWNER_PASSWORD=
